{
  "name": "aurochs-workspace",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/@aurochs/*",
    "packages/@aurochs-office/*",
    "packages/@aurochs-converters/*",
    "packages/@aurochs-renderer/*",
    "packages/@aurochs-ui/*",
    "packages/@aurochs-cli/*",
    "packages/@aurochs-builder/*",
    "packages/@aurochs-build/*",
    "packages/@aurochs-mcp/*"
  ],
  "scripts": {
    "build": "vite build --config pages/vite.config.ts && bun build packages/@aurochs-cli/cli/src/cli.ts --target node --outfile dist/aurochs-cli",
    "dist-clean": "rimraf dist",
    "test": "vitest --run",
    "typecheck": "tsc -p tsconfig.json --noEmit --rootDir .",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:pages": "vite build --config pages/vite.config.ts",
    "dev:pages": "vite --config pages/vite.config.ts",
    "dev:office-viewer": "./scripts/run-office-viewer-dev.sh",
    "changeset": "changeset",
    "version": "changeset version && bun run version:sync",
    "version:sync": "bun run scripts/version/sync-publish-versions.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/react": "^16.3.2",
    "@types/earcut": "^3.0.0",
    "@types/jpeg-js": "^0.3.7",
    "@types/node": "^24.12.0",
    "@types/opentype.js": "^1.3.9",
    "@types/pdfkit": "^0.17.5",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^8.18.0",
    "concurrently": "^9.2.1",
    "earcut": "^3.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^56.1.2",
    "jpeg-js": "^0.4.4",
    "jsdom": "^27.4.0",
    "pdfkit": "^0.18.0",
    "pixelmatch": "^7.1.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "hono": "^4.12.8",
    "opentype.js": "^1.3.4",
    "pngjs": "^7.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "rollup": "^4.60.0"
  }
}
