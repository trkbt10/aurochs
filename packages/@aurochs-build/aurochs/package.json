{
  "name": "@aurochs-build/aurochs",
  "version": "0.12.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:cli": "bun build ../../@aurochs-cli/cli/src/cli.ts --target node --outdir ../../../publish/aurochs/dist --entry-naming cli.js",
    "verify": "node scripts/verify-exports.mjs",
    "verify:cli": "node scripts/verify-cli.mjs"
  },
  "dependencies": {
    "@aurochs-builder/docx": "workspace:*",
    "@aurochs-builder/pdf": "workspace:*",
    "@aurochs-office/docx": "workspace:*",
    "@aurochs-office/ooxml": "workspace:*",
    "@aurochs-office/pptx": "workspace:*",
    "@aurochs-office/xlsx": "workspace:*",
    "@aurochs-renderer/docx": "workspace:*",
    "@aurochs-renderer/pdf": "workspace:*",
    "@aurochs-renderer/pptx": "workspace:*",
    "@aurochs-renderer/xlsx": "workspace:*",
    "@aurochs-ui/docx-editor": "workspace:*",
    "@aurochs-ui/pptx-editor": "workspace:*",
    "@aurochs-ui/xlsx-editor": "workspace:*",
    "@aurochs/pdf": "workspace:*",
    "@aurochs-cli/cli": "workspace:*"
  },
  "devDependencies": {
    "vite-plugin-dts": "^4.5.4"
  }
}
