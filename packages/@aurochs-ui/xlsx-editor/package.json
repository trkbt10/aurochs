{
  "name": "@aurochs-ui/xlsx-editor",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "dependencies": {
    "@aurochs-office/vba": "workspace:*",
    "@aurochs-office/drawing-ml": "workspace:*",
    "@aurochs-office/opc": "workspace:*",
    "@aurochs-office/xls": "workspace:*",
    "@aurochs-office/xlsx": "workspace:*",
    "@aurochs-ui/color-editor": "workspace:*",
    "@aurochs-ui/editor-core": "workspace:*",
    "@aurochs-ui/editor-controls": "workspace:*",
    "@aurochs-ui/ui-components": "workspace:*",
    "@aurochs-ui/xlsx-sheet": "workspace:*",
    "@aurochs-ui/vba-editor": "workspace:*",
    "@aurochs/zip": "workspace:*",
    "react-router-dom": "^7.13.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@aurochs-ui/xlsx-editor/src'",
    "dev:editor": "vite --config dev/vite.config.ts --open /xlsx-editor.html",
    "dev:viewer": "vite --config dev/vite.config.ts --open /xlsx-viewer.html"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./dev": {
      "types": "./src/dev/index.ts",
      "default": "./src/dev/index.ts"
    },
    "./viewer/WorkbookViewer": {
      "types": "./src/viewer/WorkbookViewer.tsx",
      "default": "./src/viewer/WorkbookViewer.tsx"
    },
    "./viewer/EmbeddableSheet": {
      "types": "./src/viewer/EmbeddableSheet.tsx",
      "default": "./src/viewer/EmbeddableSheet.tsx"
    },
    "./vba": {
      "types": "./src/vba/index.ts",
      "default": "./src/vba/index.ts"
    }
  }
}
