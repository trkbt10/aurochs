{
  "name": "@aurochs-ui/pdf-editor",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "dependencies": {
    "@aurochs/pdf": "workspace:*",
    "@aurochs-builder/pdf": "workspace:*",
    "@aurochs-renderer/pdf": "workspace:*",
    "@aurochs-renderer/svg": "workspace:*",
    "@aurochs-ui/editor-core": "workspace:*",
    "@aurochs-ui/editor-controls": "workspace:*",
    "@aurochs-ui/ui-components": "workspace:*",
    "react-editor-ui": "^0.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@aurochs-ui/pdf-editor/src'",
    "e2e:dev": "vite --config spec/e2e/vite.config.ts",
    "e2e:test": "bun run spec/e2e/pdf-editor.e2e.ts",
    "e2e:perf:dev": "vite --config spec/e2e/perf-vite.config.ts",
    "e2e:perf": "bun run spec/e2e/pdf-editor-perf.e2e.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./viewer": {
      "types": "./src/viewer/index.ts",
      "default": "./src/viewer/index.ts"
    },
    "./editor": {
      "types": "./src/editor/index.ts",
      "default": "./src/editor/index.ts"
    }
  }
}
