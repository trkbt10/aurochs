{
  "name": "@aurochs-ui/pptx-editor",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "dependencies": {
    "@aurochs-builder/chart": "workspace:*",
    "@aurochs-builder/diagram": "workspace:*",
    "@aurochs-builder/pptx": "workspace:*",
    "@aurochs-office/chart": "workspace:*",
    "@aurochs-office/drawing-ml": "workspace:*",
    "@aurochs-office/pptx": "workspace:*",
    "@aurochs-renderer/pptx": "workspace:*",
    "@aurochs-renderer/svg": "workspace:*",
    "@aurochs-ui/chart-editor": "workspace:*",
    "@aurochs-ui/color-editor": "workspace:*",
    "@aurochs-ui/diagram-editor": "workspace:*",
    "@aurochs-ui/editor-controls": "workspace:*",
    "@aurochs-ui/ooxml-components": "workspace:*",
    "@aurochs-ui/editor-core": "workspace:*",
    "@aurochs-ui/path-tools": "workspace:*",
    "@aurochs-ui/potx-editor": "workspace:*",
    "@aurochs-ui/pptx-slide-canvas": "workspace:*",
    "@aurochs-ui/pptx-viewer": "workspace:*",
    "@aurochs-ui/ui-components": "workspace:*",
    "@aurochs-ui/xlsx-editor": "workspace:*",
    "@aurochs/glyph": "workspace:*",
    "react-editor-ui": "^0.4.0",
    "react-panel-layout": "^0.7.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run --passWithNoTests --config ../../../vitest.config.ts '../../../packages/@aurochs-ui/pptx-editor/src'",
    "visual:test": "vitest --run --config ../../../vitest.config.ts '../../../packages/@aurochs-ui/pptx-editor/spec/pptx-visual.spec.ts'",
    "visual:fixtures": "bun run scripts/generate-visual-fixtures.ts",
    "visual:baselines": "bun run scripts/generate-editor-baselines.ts",
    "dev:viewer": "vite --config dev/vite.config.ts --open /pptx-viewer.html",
    "dev:slideshow": "vite --config dev/vite.config.ts --open /pptx-slideshow.html"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./adapters": {
      "types": "./src/adapters/index.ts",
      "default": "./src/adapters/index.ts"
    },
    "./dev": {
      "types": "./src/dev/index.ts",
      "default": "./src/dev/index.ts"
    }
  },
  "devDependencies": {
    "puppeteer-core": "^24.40.0",
    "vite": "^7.3.1"
  }
}
