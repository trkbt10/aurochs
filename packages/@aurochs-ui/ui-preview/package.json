{
  "name": "@aurochs-ui/ui-preview",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "description": "Aggregation hub for @aurochs-ui dev previews. No source code — HTML entry points reference each package's dev/ directly.",
  "scripts": {
    "dev": "vite --open /ui-preview/index.html",
    "dev:xlsx": "vite --open /ui-preview/xlsx-editor.html",
    "dev:xlsx-viewer": "vite --open /ui-preview/xlsx-viewer.html",
    "dev:docx": "vite --open /ui-preview/docx-editor.html",
    "dev:docx-viewer": "vite --open /ui-preview/docx-viewer.html",
    "dev:pptx-slideshow": "vite --open /ui-preview/pptx-slideshow.html",
    "dev:pptx-viewer": "vite --open /ui-preview/pptx-viewer.html",
    "dev:editor-controls": "vite --open /ui-preview/editor-controls.html",
    "dev:vba": "vite --open /ui-preview/vba-editor.html",
    "dev:ui-components": "vite --open /ui-preview/ui-components.html"
  }
}
