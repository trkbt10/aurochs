{
  "name": "@aurochs-ui/fig-editor",
  "version": "0.11.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "dependencies": {
    "@aurochs/fig": "workspace:*",
    "@aurochs-builder/fig": "workspace:*",
    "@aurochs-renderer/fig": "workspace:*",
    "@aurochs-ui/editor-core": "workspace:*",
    "@aurochs-ui/editor-controls": "workspace:*",
    "@aurochs-ui/ui-components": "workspace:*",
    "react-editor-ui": "^0.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit --rootDir ../../..",
