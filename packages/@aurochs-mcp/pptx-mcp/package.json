{
  "name": "@aurochs-mcp/pptx-mcp",
  "version": "0.11.0",
  "type": "module",
  "bin": {
    "pptx-mcp": "./src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build:ui": "vite build",
    "dev": "bun src/index.ts",
    "dev:http": "bun src/index.ts --transport http --port 3000",
    "start": "bun src/index.ts",
    "start:http": "bun src/index.ts --transport http",
    "test": "bun test spec/",
    "test:tools": "echo '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\"}' | bun src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@aurochs-cli/pptx-cli": "workspace:*",
    "@aurochs-ui/ui-components": "workspace:*",
    "hono": "^4.12.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
